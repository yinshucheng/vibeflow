{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@vibeflow/octopus-protocol": [
        "../packages/octopus-protocol/src/index.ts"
      ],
      "@vibeflow/octopus-protocol/*": [
        "../packages/octopus-protocol/src/*.ts"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}

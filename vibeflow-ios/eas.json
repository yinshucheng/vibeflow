{
  "cli": {
    "version": ">= 3.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "bundleIdentifier": "com.vibeflow.app"
      }
    },
    "preview-lite": {
      "distribution": "internal",
      "ios": {
        "bundleIdentifier": "com.vibeflow.lite"
      },
      "env": {
        "EXCLUDE_SCREEN_TIME": "true"
      }
    }
  }
}

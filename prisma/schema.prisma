// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // hashed
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects                 Project[]
  tasks                    Task[]
  pomodoros                Pomodoro[]
  goals                    Goal[]
  activityLogs             ActivityLog[]
  settings                 UserSettings?
  dailyStates              DailyState[]
  timelineEvents           TimelineEvent[]
  dailyReviews             DailyReview[]
  skipTokenUsages          SkipTokenUsage[]
  settingsModificationLogs SettingsModificationLog[]
  clientRegistries         ClientRegistry[]
  policyVersions           PolicyVersion[]
  activityAggregates       ActivityAggregate[]
  apiTokens                ApiToken[]
  dataAccessLogs           DataAccessLog[]
  focusSessions            FocusSession[]
  sleepExemptions          SleepExemption[]
  restExemptions           RestExemption[]
  dailyEntertainmentStates DailyEntertainmentState[]
  workStartRecords         WorkStartRecord[]
  blockers                 Blocker[]
  mcpAuditLogs             MCPAuditLog[]
  mcpEvents                MCPEvent[]
  mcpSubscriptions         MCPSubscription[]
  taskDecompositionFeedbacks TaskDecompositionFeedback[]
  suggestionFeedbacks      SuggestionFeedback[]
  projectTemplates         ProjectTemplate[]
  
  // Desktop Production Resilience relations
  clientConnections        ClientConnection[]
  clientOfflineEvents      ClientOfflineEvent[]
  bypassAttempts           BypassAttempt[]
  demoTokens               DemoToken[]
  demoModeEvents           DemoModeEvent[]

  // AI Chat relations
  conversations            Conversation[]
  llmUsageLogs             LLMUsageLog[]

  // Screen Time Temporary Unblock
  screenTimeExemptions     ScreenTimeExemption[]

  // State Management
  stateTransitionLogs      StateTransitionLog[]

  // Habit Tracking
  habits                   Habit[]
  habitEntries             HabitEntry[]
}

model UserSettings {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Timer settings
  pomodoroDuration  Int @default(25) // minutes
  shortRestDuration Int @default(5)
  longRestDuration  Int @default(15)
  longRestInterval  Int @default(4) // after N pomodoros
  dailyCap          Int @default(8) // max pomodoros per day

  // Airlock settings
  airlockMode String @default("optional") // required, optional, disabled

  // Browser settings
  blacklist String[] @default([])
  whitelist String[] @default([])

  // Principles
  codingStandards String[] @default([])
  preferences     Json     @default("{}")

  // Work time settings (Requirements 5.1, 5.2)
  workTimeSlots    Json     @default("[]") // WorkTimeSlot[] - array of {id, startTime, endTime, enabled}
  maxIdleMinutes   Int      @default(15) // max idle time before alert
  idleAlertActions String[] @default(["show_overlay"]) // actions on idle alert

  // Notification settings (Requirements 4.3, 4.4)
  notificationEnabled Boolean @default(true)
  notificationSound   String  @default("bell") // bell, chime, gentle, none
  flashTabEnabled     Boolean @default(true)

  // Expected time settings (Requirements 10.1, 10.2)
  expectedWorkMinutes   Int  @default(360) // 6 hours default
  expectedPomodoroCount Int  @default(10)
  weekdayExpectations   Json @default("{}") // {0-6: {workMinutes, pomodoroCount}}

  // Desktop Focus Enforcement settings (Requirements 3.1, 4.1, 5.4)
  enforcementMode     String @default("gentle") // "strict" | "gentle"
  distractionApps     Json   @default("[]") // DistractionApp[] - array of {bundleId, name, action, isPreset}
  skipTokenDailyLimit Int    @default(3) // daily skip token limit (strict: 1, gentle: 3-5)
  skipTokenMaxDelay   Int    @default(15) // max delay in minutes (strict: 5, gentle: 15)

  // Pomodoro auto-start settings (Requirements 7.1, 7.2)
  autoStartBreak        Boolean @default(false) // auto-start break after pomodoro
  autoStartNextPomodoro Boolean @default(false) // auto-start next pomodoro after break
  autoStartCountdown    Int     @default(5) // countdown seconds before auto-start

  // Browser redirect settings (Requirements 6.6)
  browserRedirectReplace Boolean @default(true) // true = replace tab, false = new tab

  // Sleep time settings (Requirements 9.1, 9.2, 9.3)
  sleepTimeEnabled     Boolean  @default(false)
  sleepTimeStart       String   @default("23:00") // "HH:mm" format
  sleepTimeEnd         String   @default("07:00") // "HH:mm" format
  sleepEnforcementApps Json     @default("[]") // SleepEnforcementApp[] - array of {bundleId, name, isPreset}
  sleepSnoozeLimit     Int      @default(2) // max snoozes per night
  sleepSnoozeDuration  Int      @default(30) // snooze duration in minutes

  // Over rest settings (Requirements 16.2, 16.3)
  overRestGracePeriod Int      @default(5) // grace period in minutes before triggering actions
  overRestActions     String[] @default(["show_notification"]) // actions: show_notification, close_browser, close_apps
  overRestApps        Json     @default("[]") // apps to close during over rest

  // Early warning settings (Requirements 26.1.1, 26.1.2, 26.1.3, 26.1.4, 26.1.5)
  earlyWarningEnabled    Boolean  @default(true)
  earlyWarningInterval   Int      @default(60) // check interval in minutes (30, 60, 120)
  earlyWarningThreshold  Int      @default(70) // warning threshold percentage (50, 60, 70, 80)
  earlyWarningMethod     String[] @default(["browser_notification"]) // notification methods
  earlyWarningQuietStart String?  // quiet hours start "HH:mm" format
  earlyWarningQuietEnd   String?  // quiet hours end "HH:mm" format

  // Entertainment settings (Requirements 9.1, 9.2, 9.3, 9.4)
  entertainmentBlacklist       Json @default("[]") // EntertainmentBlacklistEntry[] - array of {domain, isPreset, enabled, addedAt}
  entertainmentWhitelist       Json @default("[]") // EntertainmentWhitelistEntry[] - array of {pattern, description, isPreset, enabled, addedAt}
  entertainmentQuotaMinutes    Int  @default(120)  // daily entertainment quota in minutes (30-480)
  entertainmentCooldownMinutes Int  @default(30)   // cooldown between entertainment sessions in minutes (15-120)

  // Grace period settings (Requirements 5.1, 5.5, 5.6)
  gracePeriodMinutes         Int @default(5)  // default grace period in minutes (range: 1-15)
  gracePeriodPomodoroMinutes Int @default(2)  // grace period during pomodoro (shorter)

  // Demo mode settings (Requirements 6.3, 6.4, 6.13, 6.14)
  demoTokensPerMonth     Int @default(3)   // monthly demo token allocation (range: 1-10)
  demoMaxDurationMinutes Int @default(90)  // max demo mode duration in minutes (range: 30-180)

  // Bypass detection settings (Requirements 4.4)
  bypassWarningThreshold Int @default(50)  // bypass score threshold for warning (0-100)

  // Process guardian settings (Requirements 8.5, 8.6)
  enableProcessGuardian Boolean @default(true)  // enable process guardian in production
  autoStartOnLogin      Boolean @default(true)  // auto-start on system login

  // Work Apps Configuration (shared list) - REST & SLEEP enforcement
  workApps                Json               @default("[]") // [{bundleId: string, name: string}]

  // REST State Enforcement
  restEnforcementEnabled  Boolean            @default(false)
  restEnforcementActions  String[]           @default([])  // ["force_quit", "hide_window", "show_notification"]
  restGraceLimit          Int                @default(2)   // Grace times per REST cycle
  restGraceDuration       Int                @default(2)   // Minutes per grace

  // SLEEP State Enforcement (extends existing)
  sleepEnforcementActions String[]           @default(["force_quit"])  // Actions for SLEEP state

  // Health Limits Configuration
  healthLimit2Hours          Int                @default(110) // 2-hour pomodoro time limit (minutes)
  healthLimitDaily           Int                @default(600) // Daily pomodoro time limit (minutes, 10 hours)
  healthNotificationsEnabled Boolean            @default(true) // Whether health reminders are enabled
  overWorkReminderInterval   Int                @default(10)   // Minutes between repeated health reminders

  // Skip Token Configuration
  skipTokenWeeklyLimit    Int                @default(5)   // Weekly skip token quota
  skipTokenUsed           Int                @default(0)   // Tokens used this week
  skipTokenResetAt        DateTime?                        // Next reset time (Monday 00:00)

  // AI Chat Configuration (S10)
  aiTriggerConfig         Json               @default("{}") // AITriggerConfig — global toggle, quiet hours, per-trigger on/off
  aiModelConfig           Json               @default("{}") // AIModelConfig — per-scene model overrides

  // Temporary Unblock settings
  tempUnblockDailyLimit  Int @default(3)   // max per day (1-10)
  tempUnblockMaxDuration Int @default(15)  // max minutes per unblock (1-30)

  // Habit reminder settings
  habitReminderEnabled       Boolean  @default(true)   // global toggle
  habitStreakProtectEnabled   Boolean  @default(true)   // streak protection reminder
  habitStreakProtectBefore    Int      @default(120)    // minutes before sleep to remind (default 2 hours)
  habitDailySummaryEnabled   Boolean  @default(true)   // daily incomplete summary
  habitDailySummaryTime      String   @default("20:00") // summary reminder time "HH:mm"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Goal {
  id          String     @id @default(uuid())
  title       String
  description String
  type        GoalType
  targetDate  DateTime
  status      GoalStatus @default(ACTIVE)

  userId   String
  user     User          @relation(fields: [userId], references: [id])
  projects ProjectGoal[]
  habits   HabitGoal[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum GoalType {
  LONG_TERM
  SHORT_TERM
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Project {
  id          String        @id @default(uuid())
  title       String
  deliverable String
  status      ProjectStatus @default(ACTIVE)

  userId String
  user   User          @relation(fields: [userId], references: [id])
  tasks  Task[]
  goals  ProjectGoal[]
  habits Habit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProjectGoal {
  id        String  @id @default(uuid())
  projectId String
  goalId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal      Goal    @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([projectId, goalId])
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Task {
  id               String     @id @default(uuid())
  title            String
  status           TaskStatus @default(TODO)
  priority         Priority   @default(P2)
  planDate         DateTime?
  sortOrder        Int        @default(0)
  estimatedMinutes Int?       // estimated time in minutes (Requirements 20.1, 20.2)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  parentId String?
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id])
  subTasks Task[]  @relation("SubTasks")

  userId    String
  user      User       @relation(fields: [userId], references: [id])
  pomodoros Pomodoro[]
  blockers  Blocker[]
  taskDecompositionFeedbacks TaskDecompositionFeedback[]
  timeSlices TaskTimeSlice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum Priority {
  P1
  P2
  P3
}

model Pomodoro {
  id        String         @id @default(uuid())
  duration  Int // planned duration in minutes
  startTime DateTime       @default(now())
  endTime   DateTime?
  status    PomodoroStatus @default(IN_PROGRESS)
  summary   String? // completion summary

  // Multi-task enhancement fields
  taskId          String? // nullable for taskless pomodoros
  task            Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  isTaskless      Boolean  @default(false) // true if started via "Start Focus Time"
  taskSwitchCount Int      @default(0) // number of task switches during this pomodoro
  label           String?  // optional label for taskless pomodoros

  userId String
  user   User   @relation(fields: [userId], references: [id])

  timeSlices     TaskTimeSlice[]
  restExemptions RestExemption[]

  createdAt DateTime @default(now())
}

// TaskTimeSlice model for multi-task pomodoro tracking
// Records time spent on each task within a pomodoro session
model TaskTimeSlice {
  id              String    @id @default(uuid())
  pomodoroId      String
  pomodoro        Pomodoro  @relation(fields: [pomodoroId], references: [id], onDelete: Cascade)
  taskId          String?   // nullable for taskless time
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  startTime       DateTime  @default(now())
  endTime         DateTime?
  durationSeconds Int       @default(0)
  isFragment      Boolean   @default(false) // true if < 30 seconds

  @@index([pomodoroId])
  @@index([taskId])
}

enum PomodoroStatus {
  IN_PROGRESS
  COMPLETED
  ABORTED
  INTERRUPTED
}

model ActivityLog {
  id       String  @id @default(uuid())
  url      String
  title    String?
  duration Int // seconds
  category String // productive, neutral, distracting
  source   String // chrome_ext, desktop_ghost

  userId String
  user   User   @relation(fields: [userId], references: [id])

  timestamp DateTime @default(now())
}

model DailyState {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  date             DateTime @db.Date
  systemState      String // IDLE, FOCUS, OVER_REST (legacy: LOCKED, PLANNING, REST)
  top3TaskIds      String[]
  pomodoroCount    Int      @default(0)
  capOverrideCount Int      @default(0)
  airlockCompleted Boolean  @default(false)
  adjustedGoal     Int?     // temporary goal adjustment for today only (Requirements 23.1, 23.2, 23.3)

  // State engine context persistence fields
  lastPomodoroEndTime DateTime?  // Last pomodoro completion time, used for rest duration → OVER_REST trigger
  overRestEnteredAt   DateTime?  // Time when OVER_REST was entered, used for cooldown calculation
  overRestExitCount   Int       @default(0)  // Today's count of voluntary OVER_REST exits (max 3)

  @@unique([userId, date])
}

// State Transition Log for state management observability
// Records every state transition for debugging and analytics (30-day retention)
model StateTransitionLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  fromState String
  toState   String
  event     String
  context   String?  // JSON, event-related context (e.g. pomodoroId)
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@index([userId, fromState, toState])
}

// Timeline Event model for activity tracking (Requirements 6.1, 8.1, 8.2)
model TimelineEvent {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Event type: pomodoro, distraction, break, scheduled_task, activity_log, block, state_change, interruption, idle
  type String

  // Time information
  startTime DateTime
  endTime   DateTime?
  duration  Int // seconds

  // Event title/description
  title String

  // Metadata (varies by event type)
  // activity_log: { url, category }
  // block: { url, blockType, userAction, pomodoroId }
  // state_change: { fromState, toState, trigger }
  // interruption: { source, pomodoroId, details }
  // idle: { withinWorkHours, alertTriggered }
  metadata Json @default("{}")

  // Source of the event
  source String @default("browser_sentinel")

  createdAt DateTime @default(now())

  @@index([userId, startTime])
  @@index([userId, type])
  @@index([userId, type, startTime])
}

// Daily Review model for tracking expected vs actual performance (Requirements 10.1, 10.2)
model DailyReview {
  id     String   @id @default(uuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  date   DateTime @db.Date

  // Expected values (recorded at the time for historical comparison)
  expectedWorkMinutes   Int
  expectedPomodoroCount Int

  // Actual values
  actualWorkMinutes    Int @default(0)
  completedPomodoros   Int @default(0)
  interruptedPomodoros Int @default(0)
  abortedPomodoros     Int @default(0)

  // Website usage statistics
  productiveMinutes  Int @default(0)
  distractingMinutes Int @default(0)
  neutralMinutes     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

// Skip Token Usage model for tracking daily skip/delay token consumption (Requirements 5.4, 5.7)
model SkipTokenUsage {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  usedCount Int      @default(0)

  @@unique([userId, date])
  @@index([userId])
}

// Settings Modification Log for audit trail (Requirements 8.7)
model SettingsModificationLog {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  settingKey String
  oldValue   Json?
  newValue   Json?
  success    Boolean
  reason     String? // If failed, record the reason
  timestamp  DateTime @default(now())

  @@index([userId, timestamp])
}

// Client Registry for Octopus Architecture (Requirements 9.1, 9.2)
// Tracks connected client instances (web, desktop, browser_ext, mobile)
model ClientRegistry {
  id            String    @id @default(uuid())
  clientId      String    @unique
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientType    String    // 'web' | 'desktop' | 'browser_ext' | 'mobile'
  clientVersion String
  platform      String    // 'macos' | 'windows' | 'linux' | 'ios' | 'android' | 'chrome'
  capabilities  String[]  // ['sensor:app', 'action:close_app', etc.]
  deviceName    String?
  status        String    @default("offline") // 'online' | 'offline'
  lastSeenAt    DateTime  @default(now())
  registeredAt  DateTime  @default(now())
  revokedAt     DateTime?

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

// Policy Version for Octopus Architecture (Requirements 10.6)
// Stores versioned policy snapshots for distribution to clients
model PolicyVersion {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version   Int
  policy    Json     // Policy object containing blacklist, whitelist, enforcementMode, etc.
  createdAt DateTime @default(now())

  @@unique([userId, version])
  @@index([userId])
}

// Command Queue for Octopus Architecture (Requirements 2.6, 2.7)
// Manages command queuing for offline clients with acknowledgment tracking
model CommandQueue {
  id             String    @id @default(uuid())
  commandId      String    @unique
  clientId       String
  userId         String
  commandType    String    // 'SYNC_STATE' | 'EXECUTE_ACTION' | 'UPDATE_POLICY' | 'SHOW_UI'
  payload        Json
  priority       String    @default("normal") // 'low' | 'normal' | 'high' | 'critical'
  requiresAck    Boolean   @default(false)
  status         String    @default("pending") // 'pending' | 'delivered' | 'acknowledged' | 'expired'
  expiryTime     DateTime?
  createdAt      DateTime  @default(now())
  deliveredAt    DateTime?
  acknowledgedAt DateTime?

  @@index([clientId, status])
  @@index([userId])
  @@index([expiryTime])
  @@index([status, expiryTime])
}

// Activity Aggregate for Octopus Architecture (Requirements 11.1, 11.4)
// Stores aggregated activity data from all sources for analytics
model ActivityAggregate {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date           DateTime @db.Date
  source         String   // 'browser' | 'desktop_app' | 'mobile_app'
  category       String   // 'productive' | 'neutral' | 'distracting'
  totalDuration  Int      // seconds
  activityCount  Int      // number of activity events aggregated
  topIdentifiers Json     // Array of top activities [{identifier, title, duration}]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, date, source, category])
  @@index([userId, date])
  @@index([userId, source])
}


// API Token for client authentication (Requirements 1.6, 13.2)
// Allows clients (browser extension, desktop, mobile) to authenticate without session cookies
model ApiToken {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token       String    @unique // hashed token
  name        String    // user-friendly name for the token
  clientType  String    // 'web' | 'desktop' | 'browser_ext' | 'mobile'
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// Data Access Log for audit trail (Requirements 13.3)
// Tracks data access for security auditing and user data isolation verification
model DataAccessLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action      String   // 'read' | 'write' | 'delete'
  resource    String   // 'task' | 'project' | 'pomodoro' | 'settings' | etc.
  resourceId  String?  // ID of the accessed resource
  clientId    String?  // Client that performed the action
  clientType  String?  // Type of client
  ipAddress   String?  // IP address (if available)
  success     Boolean  @default(true)
  details     Json?    // Additional details about the access
  timestamp   DateTime @default(now())

  @@index([userId, timestamp])
  @@index([resource, timestamp])
  @@index([userId, resource])
}


// Focus Session model for Ad-hoc Focus Session feature (Requirements 1.1, 1.2, 8.1)
// Tracks temporary focus sessions started outside regular work hours
model FocusSession {
  id               String    @id @default(uuid())
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startTime        DateTime  @default(now())
  plannedEndTime   DateTime
  actualEndTime    DateTime?
  duration         Int       // planned duration in minutes (15-240)
  status           String    @default("active") // 'active' | 'completed' | 'cancelled'
  overridesSleepTime  Boolean @default(false)
  overridesWorkHours Boolean @default(false)
  createdAt          DateTime  @default(now())

  sleepExemptions  SleepExemption[]

  @@index([userId])
  @@index([userId, status])
  @@index([status, plannedEndTime])
}

// Sleep Exemption model for tracking sleep time overrides (Requirements 14.1, 14.2)
// Records snooze events and focus session overrides during sleep time
model SleepExemption {
  id             String        @id @default(uuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type           String        // 'snooze' | 'focus_override'
  timestamp      DateTime      @default(now())
  duration       Int           // duration in minutes
  focusSessionId String?
  focusSession   FocusSession? @relation(fields: [focusSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, timestamp])
}

// Rest Exemption model for tracking REST state overrides
// Records grace and skip rest usage during REST state
model RestExemption {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  pomodoroId String?
  pomodoro   Pomodoro? @relation(fields: [pomodoroId], references: [id])
  type       String    // "grace" or "skip"
  grantedAt  DateTime  @default(now())
  expiresAt  DateTime?

  @@index([userId, grantedAt])
  @@index([pomodoroId])
}

// Screen Time Temporary Unblock model
// Records temporary unblock exemptions granted via AI chat
model ScreenTimeExemption {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  blockingReason  String    // 'focus' | 'over_rest' | 'sleep'
  reasonText      String    // user-provided reason for unblocking
  duration        Int       // unblock duration in minutes
  grantedAt       DateTime  @default(now())
  expiresAt       DateTime  // grantedAt + duration
  revokedAt       DateTime? // early revocation time (reserved)

  @@index([userId])
  @@index([userId, grantedAt])
  @@index([userId, expiresAt])
}

// Daily Entertainment State model for tracking entertainment quota usage (Requirements 8.1, 8.7)
// Tracks daily entertainment mode usage, quota consumption, and cooldown status
model DailyEntertainmentState {
  id     String   @id @default(uuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  // Quota usage
  quotaUsedMinutes Int @default(0)

  // Current session
  activeSessionId  String?
  sessionStartTime DateTime?

  // Cooldown status
  lastSessionEndTime DateTime?

  // Statistics
  sessionCount  Int      @default(0)
  sitesVisited  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId])
}

// Work Start Record model for tracking work start times (Requirements 14.1, 14.2, 14.7, 14.8)
// Records when user completes Airlock to track work avoidance patterns
model WorkStartRecord {
  id     String   @id @default(uuid())
  userId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date   DateTime @db.Date

  configuredStartTime String   // HH:mm format - the configured work start time
  actualStartTime     DateTime // actual timestamp when Airlock was completed
  delayMinutes        Int      // 0 if on-time or early, positive if late

  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId])
  @@index([userId, date])
}

// Blocker model for AI-Native Enhancement (Requirements 5.1, 5.2, 5.4, 5.5)
// Tracks blockers reported by users or detected by the system
model Blocker {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  category    String   // 'technical' | 'dependency' | 'unclear_requirements' | 'other'
  description String
  status      String   @default("active") // 'active' | 'resolved'
  resolution  String?

  // External dependency tracking (Requirement 5.4)
  dependencyType       String?   // 'person' | 'system' | 'external'
  dependencyIdentifier String?
  expectedResolution   DateTime?

  reportedAt DateTime  @default(now())
  resolvedAt DateTime?

  @@index([userId, status])
  @@index([taskId])
  @@index([userId])
}


// MCP Audit Log model for AI-Native Enhancement (Requirement 4.5)
// Tracks all MCP tool calls for audit and learning purposes
model MCPAuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  agentId   String
  toolName  String
  input     Json
  output    Json
  success   Boolean
  duration  Int      // milliseconds
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@index([toolName])
  @@index([agentId])
}

// MCP Event model for AI-Native Enhancement (Requirement 10.5)
// Stores event history for the last 24 hours for late-joining agents
model MCPEvent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 'task.status_changed' | 'pomodoro.started' | 'daily_state.changed' | etc.
  payload   Json
  timestamp DateTime @default(now())

  @@index([userId, timestamp])
  @@index([type])
  @@index([userId, type, timestamp])
}

// MCP Subscription model for AI-Native Enhancement (Requirements 10.1, 10.2, 10.3)
// Tracks event subscriptions for AI agents
model MCPSubscription {
  id         String   @id @default(uuid())
  agentId    String
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventTypes String[] // Array of event type strings
  createdAt  DateTime @default(now())

  @@unique([agentId, userId])
  @@index([userId])
  @@index([agentId])
}


// Task Decomposition Feedback model for AI-Native Enhancement (Requirement 2.5)
// Records user acceptance/rejection patterns for task decomposition suggestions
model TaskDecompositionFeedback {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  suggestions Json     // Original suggestions array
  accepted    String[] // Accepted suggestion titles
  rejected    String[] // Rejected suggestion titles
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([taskId])
}

// Suggestion Feedback model for AI-Native Enhancement (Requirements 3.5, 9.5)
// Records user feedback on task suggestions for learning
model SuggestionFeedback {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestionId String
  taskId       String?
  action       String   // 'accepted' | 'dismissed' | 'modified'
  context      Json?    // Trigger context (pomodoro_complete, idle_detected, airlock_entry, manual)
  createdAt    DateTime @default(now())

  @@index([userId, createdAt])
  @@index([suggestionId])
}

// Project Template model for AI-Native Enhancement (Requirement 4.2)
// Stores project templates for scaffolding new projects
model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  structure   Json     // Template structure definition with tasks
  isSystem    Boolean  @default(false) // System preset vs user-defined
  userId      String?  // null for system templates
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([isSystem])
}

// ============================================================================
// Desktop Production Resilience Models (Requirements 3.2, 3.4, 4.1, 6.2, 6.10)
// ============================================================================

// Client Connection model for heartbeat tracking (Requirements 3.2, 3.3, 3.4, 3.5)
// Tracks connected client instances with heartbeat status
model ClientConnection {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId      String    @unique
  deviceName    String?
  appVersion    String
  mode          String    // 'development' | 'staging' | 'production'
  lastHeartbeat DateTime
  isOnline      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  offlineEvents ClientOfflineEvent[]

  @@index([userId])
  @@index([lastHeartbeat])
  @@index([isOnline])
}

// Client Offline Event model for tracking disconnections (Requirements 3.4, 3.5, 5.3, 5.4)
// Records client offline events with duration and context
model ClientOfflineEvent {
  id              String    @id @default(uuid())
  clientId        String
  client          ClientConnection @relation(fields: [clientId], references: [clientId], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  startedAt       DateTime
  endedAt         DateTime?
  durationSeconds Int?
  wasInWorkHours  Boolean
  wasInPomodoro   Boolean
  gracePeriodUsed Boolean   @default(false)
  isBypassAttempt Boolean   @default(false)

  @@index([userId])
  @@index([startedAt])
  @@index([clientId])
}

// Bypass Attempt model for tracking bypass events (Requirements 4.1, 4.2, 4.3, 4.4, 4.5)
// Records bypass attempts with severity and context
model BypassAttempt {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId        String
  eventType       String   // 'force_quit' | 'offline_timeout' | 'guardian_killed'
  timestamp       DateTime @default(now())
  durationSeconds Int?     // offline duration in seconds
  wasInWorkHours  Boolean
  wasInPomodoro   Boolean
  warningLevel    String   // 'none' | 'low' | 'medium' | 'high'

  @@index([userId])
  @@index([timestamp])
  @@index([userId, timestamp])
}

// Demo Token model for demo mode activation (Requirements 6.2, 6.3, 6.4, 6.10)
// Tracks demo token allocation and usage
model DemoToken {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  allocatedAt     DateTime  @default(now())
  expiresAt       DateTime  // month end expiry
  usedAt          DateTime?
  endedAt         DateTime?
  durationMinutes Int?      // actual usage duration
  confirmPhrase   String?   // confirmation phrase used

  demoModeEvents  DemoModeEvent[]

  @@index([userId])
  @@index([expiresAt])
  @@index([userId, expiresAt])
}

// Demo Mode Event model for timeline display (Requirements 6.8, 6.11)
// Records demo mode events for timeline and statistics
model DemoModeEvent {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId         String
  token           DemoToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  eventType       String   // 'started' | 'ended' | 'expired'
  timestamp       DateTime @default(now())
  durationMinutes Int?     // only for 'ended' | 'expired' events
  reason          String?  // 'manual_exit' | 'duration_expired' | 'token_exhausted'

  @@index([userId])
  @@index([timestamp])
  @@index([userId, timestamp])
}

// ===== AI Chat Models =====

enum ConversationType {
  DEFAULT
  DAILY
  TOPIC
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

model Conversation {
  id        String             @id @default(uuid())
  userId    String
  type      ConversationType   @default(DEFAULT)
  status    ConversationStatus @default(ACTIVE)
  title     String?            @default("VibeFlow Assistant")
  date      String?            // reserved for DAILY type (YYYY-MM-DD)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     ChatMessage[]
  llmUsageLogs LLMUsageLog[]

  @@index([userId, type, status])
  @@index([userId, updatedAt])
}

model ChatMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String   // 'user' | 'assistant' | 'tool_call' | 'tool_result' | 'system'
  content        String
  metadata       Json?    // toolCallId, toolName, parameters, isProactive, triggerId etc.
  tokenCount     Int?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model LLMUsageLog {
  id                  String   @id @default(uuid())
  userId              String
  conversationId      String
  messageId           String?
  scene               String   // 'chat:default', 'chat:quick_action', 'trigger:xxx', etc.
  model               String   // MODEL_REGISTRY key, e.g. 'qwen-plus', 'kimi-k2'
  inputTokens         Int
  outputTokens        Int
  totalTokens         Int      // inputTokens + outputTokens
  contextLength       Int      // actual context length in tokens
  maxContextLimit     Int      // model's context window limit
  contextUsagePercent Float    // contextLength / maxContextLimit * 100
  createdAt           DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id])

  @@index([userId, createdAt])
  @@index([conversationId])
}

// ===== Habit Tracking Models =====

enum HabitType {
  BOOLEAN     // 打卡型：做了/没做
  MEASURABLE  // 计数型：喝了几杯水
  TIMED       // 时长型：冥想了多少分钟
}

enum HabitStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum HabitEntryType {
  NO           // 明确标记未完成
  UNKNOWN      // 未操作（历史空白天）
  YES_MANUAL   // 用户手动打卡
  YES_AUTO     // 番茄钟自动累计
  SKIP         // 主动跳过（不中断 streak）
}

model Habit {
  id          String      @id @default(uuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id])

  title       String
  description String?
  question    String?     // "今天做了吗？" — 用于通知和 AI 提示

  // 类型与目标
  type        HabitType   // BOOLEAN | MEASURABLE | TIMED
  targetValue Float?      // MEASURABLE: 目标数量, TIMED: 目标分钟数, BOOLEAN: null
  targetUnit  String?     // "杯", "页", "分钟" 等

  // 频率（分数模型）
  freqNum     Int         @default(1)  // 分子：周期内需完成次数
  freqDen     Int         @default(1)  // 分母：周期长度（天）

  // 关联
  projectId   String?
  project     Project?    @relation(fields: [projectId], references: [id])
  goals       HabitGoal[]

  // 显示
  icon        String?     // Lucide icon name
  color       String?     // hex color
  sortOrder   Int         @default(0)
  status      HabitStatus @default(ACTIVE) // ACTIVE | PAUSED | ARCHIVED

  // 提醒设置
  reminderEnabled  Boolean  @default(false)
  reminderTime     String?  // "HH:mm" 格式，如 "08:00"

  entries     HabitEntry[]

  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId, status])
  @@index([userId, projectId])
}

model HabitEntry {
  id         String          @id @default(uuid())
  habitId    String
  habit      Habit           @relation(fields: [habitId], references: [id], onDelete: Cascade)
  userId     String
  user       User            @relation(fields: [userId], references: [id])
  date       DateTime        @db.Date    // 使用 getTodayDate() 计算（04:00 AM 重置），客户端传 YYYY-MM-DD
  value      Float                       // BOOLEAN: 必须为 1, MEASURABLE: 实际数(>0), TIMED: 分钟数(>0)
  entryType  HabitEntryType  @default(YES_MANUAL)
  note       String?
  pomodoroIds String[]       @default([]) // TIMED 类型：累计贡献的番茄钟 ID 列表（可溯源）

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([habitId, date])
  @@index([habitId, date])
  @@index([userId, date])
}

model HabitGoal {
  id      String @id @default(uuid())
  habitId String
  goalId  String
  habit   Habit  @relation(fields: [habitId], references: [id], onDelete: Cascade)
  goal    Goal   @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([habitId, goalId])
}

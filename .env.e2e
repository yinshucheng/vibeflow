# E2E test environment — committed to repo, no secrets
# Note: DATABASE_URL uses macOS peer auth (no password).
# If your PostgreSQL setup requires a password, add it here.
PORT=3200
NEXTAUTH_URL="http://localhost:3200"
NEXTAUTH_SECRET="e2e-test-secret-not-for-production"
DEV_MODE="true"
NEXT_PUBLIC_DEV_MODE="true"
DEV_USER_EMAIL="e2e@vibeflow.local"

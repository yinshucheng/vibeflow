{
  "info": {
    "name": "VibeFlow API",
    "description": "Comprehensive API collection for VibeFlow productivity app",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "noauth"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Set dev auth header for all requests",
          "pm.request.headers.add({",
          "  key: 'X-Dev-User-Email',",
          "  value: pm.environment.get('DEV_USER_EMAIL') || 'test@example.com'",
          "});",
          "",
          "// Set content type for POST/PUT/PATCH requests",
          "if (['POST', 'PUT', 'PATCH'].includes(pm.request.method)) {",
          "  pm.request.headers.add({",
          "    key: 'Content-Type',",
          "    value: 'application/json'",
          "  });",
          "}"
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "DEV_USER_EMAIL",
      "value": "test@example.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "Server Health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "response": []
        },
        {
          "name": "Heartbeat",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/trpc/heartbeat.ping",
              "host": ["{{baseUrl}}"],
              "path": ["api", "trpc", "heartbeat.ping"]
            }
          },
          "response": []
        }
      ]
    },

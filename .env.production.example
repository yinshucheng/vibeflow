# =============================================================================
# VibeFlow Production Environment
# =============================================================================
# Copy to .env.production and fill in real values.
# This file is deployed to the server alongside docker-compose.yml.
# =============================================================================

# Database (Aliyun RDS PostgreSQL - use internal network address)
DATABASE_URL="postgresql://user:password@rm-xxx.pg.rds.aliyuncs.com:5432/vibeflow?schema=public"

# NextAuth
NEXTAUTH_URL="http://<server-ip>:4000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Development Mode (set to false for production, true for now during early access)
DEV_MODE="true"
DEV_USER_EMAIL="ithinker1991@gmail.com"

# LLM Providers (optional, for AI features)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

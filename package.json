{
  "name": "vibeflow",
  "version": "1.0.0",
  "description": "AI-Native Output Engine",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "tsx watch --clear-screen=false server.ts",
    "dev:sandbox": "dotenv -e .env.dev -- tsx watch --clear-screen=false server.ts",
    "dev:next": "next dev",
    "dev:socket": "tsx watch --clear-screen=false server.ts",
    "dev:mcp": "tsx watch --clear-screen=false src/mcp/run.ts",
    "build": "next build",
    "build:server": "tsc --project tsconfig.server.json && tsc-alias -p tsconfig.server.json",
    "start": "next start",
    "start:socket": "node dist/server.js",
    "start:mcp": "node dist/mcp/run.js",
    "lint": "next lint",
    "test": "vitest --run --config vitest.config.ts",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "dev:feat": "./scripts/env-manager.sh start",
    "env:create": "./scripts/env-manager.sh create",
    "env:destroy": "./scripts/env-manager.sh destroy",
    "env:list": "./scripts/env-manager.sh list",
    "vibeflow": "./scripts/vibeflow.sh",
    "vibeflow:start": "./scripts/vibeflow.sh start",
    "vibeflow:stop": "./scripts/vibeflow.sh stop",
    "vibeflow:restart": "./scripts/vibeflow.sh restart",
    "vibeflow:status": "./scripts/vibeflow.sh status",
    "vibeflow:logs": "./scripts/vibeflow.sh logs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ai-sdk/openai": "^3.0.35",
    "@modelcontextprotocol/sdk": "^1.25.1",
    "@prisma/client": "^6.2.1",
    "@tanstack/react-query": "^5.90.14",
    "@trpc/client": "^11.0.0",
    "@trpc/next": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "ai": "^6.0.103",
    "autoprefixer": "^10.4.20",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^0.563.0",
    "next": "^14.2.23",
    "next-auth": "^4.24.13",
    "postcss": "^8.5.1",
    "prisma": "^6.2.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "superjson": "^2.2.6",
    "tailwindcss": "^3.4.17",
    "xstate": "^5.19.2",
    "zod": "^3.24.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.3",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.4",
    "fast-check": "^3.23.2",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}

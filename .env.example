# =============================================================================
# VibeFlow Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Environment Isolation:
#   prod  (npm run dev)     → .env          → vibeflow       → port 3000
#   test  (npm test)        → .env.test     → vibeflow_test  → no server
#   e2e   (npm run e2e)     → .env.e2e      → vibeflow_e2e   → port 3200
#   feat  (npm run dev:feat)→ .envs/        → vibeflow_feat_ → port 3101+
#
# Test and E2E databases are auto-created. No manual setup needed.
# =============================================================================

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vibeflow?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# Development Mode
DEV_MODE="true"
DEV_USER_EMAIL="ithinker1991@gmail.com"
NEXT_PUBLIC_DEV_MODE="true"

# LLM Providers
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1

SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# LLM Model Override (optional, override default model per scene)
# LLM_MODEL_CHAT_DEFAULT=qwen-plus
# LLM_MODEL_CHAT_QUICK_ACTION=qwen-turbo

{
  "manifest_version": 3,
  "name": "VibeFlow Browser Sentinel",
  "version": "1.0.0",
  "description": "Browser activity tracking and focus mode enforcement for VibeFlow",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content/overlay.js"],
      "css": ["dist/content/overlay.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["dist/content/interaction-tracker.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "VibeFlow Browser Sentinel"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "blocking_rules",
        "enabled": true,
        "path": "rules/blocking_rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "screensaver.html", 
        "locked-screensaver.html", 
        "over-rest-screensaver.html",
        "dist/content/overlay.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}

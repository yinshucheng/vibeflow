{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "noEmit": false,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["server.ts", "src/server/**/*.ts", "src/lib/**/*.ts", "src/services/**/*.ts", "src/mcp/**/*.ts", "src/types/**/*.ts", "src/machines/**/*.ts", "src/middleware/**/*.ts"],
  "exclude": [
    "node_modules",
    "**/*.test.ts",
    "**/*.spec.ts",
    "src/components/**/*",
    "src/services/tray-integration.service.ts"
  ]
}

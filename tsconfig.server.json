{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "noEmit": false,
    "esModuleInterop": true
  },
  "include": ["server.ts", "src/server/**/*.ts", "src/lib/**/*.ts", "src/services/**/*.ts"],
  "exclude": ["node_modules"]
}
